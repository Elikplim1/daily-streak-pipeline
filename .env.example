# Supabase — use SESSION POOLER URL (port 5432, pooler.supabase.com)
# NOT the direct db.*.supabase.co format (IPv6, fails on most networks)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-1-eu-north-1.pooler.supabase.com:5432/postgres

# API-Football (Mega plan — 300 req/min)
API_FOOTBALL_KEY=
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io
API_FOOTBALL_RATE_LIMIT=300

# Telegram — shadow mode active until SHADOW_MODE=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Pipeline control
SHADOW_MODE=true
LOG_LEVEL=INFO
